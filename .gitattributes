# Force LF line endings for all text files (works on macOS, Linux, and Windows)
* text=auto eol=lf

# Explicitly mark common text file types
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.csv text eol=lf
*.sh text eol=lf

# Binary files — don't touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.xlsx binary
*.pptx binary
*.zip binary
*.tar.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
